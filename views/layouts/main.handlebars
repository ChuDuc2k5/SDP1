<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Serene Stays - Luxury Getaway</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-stone-900 text-stone-100 font-sans">

    <nav
        class="bg-stone-950/50 backdrop-blur-md border-b border-stone-800 sticky top-0 z-50 px-8 py-4 flex justify-between items-center">
        <a href="/" class="text-2xl font-serif font-bold text-yellow-500 tracking-tighter">
            SERENE STAYS
        </a>

        <div class="flex gap-8 items-center text-stone-300 font-medium">
            <a href="/" class="hover:text-yellow-500 transition-colors">About</a>
            <a href="/cabins" class="hover:text-yellow-500 transition-colors">Our Cabins</a>
            {{#if user}}
            <div class="dropdown">
                <button
                    class="flex items-center gap-2 bg-stone-800 px-4 py-2 rounded-full border border-stone-700 dropdown-toggle"
                    data-bs-toggle="dropdown">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-500" viewBox="0 0 20 20"
                        fill="currentColor">
                        <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" />
                    </svg>
                    <span>{{user.fullName}}</span>
                </button>

                <ul class="dropdown-menu dropdown-menu-end bg-dark border border-secondary">
                    {{#if (eq user.role 'admin')}}
                    <li>
                        <a class="dropdown-item text-light hover:bg-stone-700 hover:text-yellow-400 transition"
                            href="/admin/cabins">
                            Manage Cabins
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item text-light hover:bg-stone-700 hover:text-yellow-400 transition"
                            href="/booking">
                            Booking Management  
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item text-light hover:bg-stone-700 hover:text-yellow-400 transition"
                            href="/admin/settings">
                            Admin Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider bg-secondary"></li>
                    {{/if}}
                    <li>
                        <a class="dropdown-item text-light hover:bg-stone-700 hover:text-yellow-400 transition"
                            href="/booking">
                            My Booking
                        </a>
                    </li>
                    <li>
                        <a href="/user/profile"
                            class="dropdown-item text-light hover:bg-stone-700 hover:text-yellow-400 transition">
                            Profile
                        </a>
                    </li>
                    <li>
                        <form method="POST" action="/auth/logout">
                            <button class="dropdown-item text-danger hover:bg-red-900 hover:text-red-400 transition">
                                Logout
                            </button>
                        </form>
                    </li>
                </ul>
            </div>

            {{else}}
            <a href="/auth/login"
                class="flex items-center gap-2 bg-stone-800 hover:bg-stone-700 px-4 py-2 rounded-full border border-stone-700 transition-all">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-yellow-500" viewBox="0 0 20 20"
                    fill="currentColor">
                    <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z"
                        clip-rule="evenodd" />
                </svg>
                <span>Login</span>
            </a>
            {{/if}}
        </div>
    </nav>

    <main>
        {{{body}}}
    </main>

    <footer class="border-t border-stone-800 p-8 text-center text-stone-500 text-sm">
        &copy; 2026 Serene Stays Luxury Retreat. All rights reserved.
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>

</html>