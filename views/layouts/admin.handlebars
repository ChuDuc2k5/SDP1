<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard - Serene Stays</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-900 text-stone-100 font-sans flex h-screen overflow-hidden">

    <aside class="w-64 bg-stone-950 border-r border-stone-800 flex flex-col flex-shrink-0">
        <div class="h-20 flex items-center px-8 border-b border-stone-800">
            <a href="/admin" class="text-2xl font-serif font-bold text-yellow-500 tracking-tighter flex flex-col">
                SERENE STAYS
                <span class="text-xs font-sans text-stone-500 tracking-widest uppercase mt-1 text-white">Admin Panel</span>
            </a>
        </div>

        <nav class="flex-1 p-4 space-y-2 overflow-y-auto">
            <a href="/admin/cabins" class="flex items-center gap-3 px-4 py-3 rounded-xl text-stone-300 hover:bg-stone-800 hover:text-yellow-500 transition-all border border-transparent hover:border-stone-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Manage Cabins
            </a>

            <a href="/admin/orders" class="flex items-center gap-3 px-4 py-3 rounded-xl text-stone-300 hover:bg-stone-800 hover:text-yellow-500 transition-all border border-transparent hover:border-stone-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" />
                </svg>
                Manage Orders
            </a>

            <a href="/admin/settings" class="flex items-center gap-3 px-4 py-3 rounded-xl text-stone-300 hover:bg-stone-800 hover:text-yellow-500 transition-all border border-transparent hover:border-stone-700">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                Settings
            </a>
        </nav>
    </aside>

    <div class="flex-1 flex flex-col h-screen overflow-hidden bg-stone-900/50">
        
        <header class="h-20 bg-stone-950/50 backdrop-blur-md border-b border-stone-800 flex justify-end items-center px-8 gap-8">
            
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-yellow-500 flex items-center justify-center text-stone-900 font-bold shadow-inner">
                    A
                </div>
                <div class="flex flex-col">
                    <span class="text-sm font-medium text-stone-200">Welcome, Lê Đức</span>
                    <span class="text-[10px] text-stone-500 uppercase tracking-widest">Administrator</span>
                </div>
            </div>

            <a href="/logout" class="flex items-center gap-2 bg-stone-900 hover:bg-red-900/20 text-stone-400 hover:text-red-400 px-4 py-2 rounded-xl transition-all border border-stone-800 hover:border-red-900/50 group">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                <span class="text-sm font-medium">Logout</span>
            </a>

        </header>

        <main class="flex-1 overflow-y-auto p-8">
            {{{body}}}
        </main>
    </div>

</body>
</html>