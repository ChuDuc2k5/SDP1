<section class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-yellow-500 mb-6">
        Booking Details
    </h1>

    <div class="bg-stone-800 p-6 rounded-xl border border-stone-700">

        {{#if rateSuccess}}
        <div class="bg-green-500/10 border border-green-500 text-green-400 px-4 py-2 rounded-lg mb-4">
            Rating submitted successfully.
        </div>
        {{/if}}

        {{#if rateError}}
        <div class="bg-red-500/10 border border-red-500 text-red-400 px-4 py-2 rounded-lg mb-4">
            Failed to submit rating. Please try again.
        </div>
        {{/if}}

        <h2 class="text-xl font-semibold mb-4">
            {{booking.cabin.name}}
        </h2>

        <div class="space-y-2 text-stone-300">
            <p><strong>Check-in:</strong> {{booking.startDate}}</p>
            <p><strong>Check-out:</strong> {{booking.endDate}}</p>
            <p><strong>Guests:</strong> {{booking.numGuests}}</p>
            <p><strong>Type:</strong> {{booking.type}}</p>
            <p><strong>Price:</strong> ${{booking.cabinPrice}}</p>
            <p><strong>Status:</strong>
                <span class="
                    {{#if (eq booking.status 'confirmed')}}text-green-400{{/if}}
                    {{#if (eq booking.status 'cancelled')}}text-red-400{{/if}}
                ">
                    {{booking.status}}
                </span>
            </p>
            <p><strong>Note:</strong> {{booking.observations}}</p>
        </div>

        <div class="mt-6 flex gap-4">
            <a href="/booking/edit/{{booking._id}}"
                class="bg-yellow-500 text-black px-4 py-2 rounded-lg hover:bg-yellow-400">
                Edit Booking
            </a>

            <form action="/booking/edit/{{booking._id}}/cancel" method="POST">
                <button class="bg-red-600 px-4 py-2 rounded-lg hover:bg-red-500">
                    Cancel Booking
                </button>
            </form>
        </div>

        <div class="mt-8 pt-6 border-t border-stone-700">
            <h3 class="text-lg font-semibold text-yellow-400 mb-3">Your Rating</h3>

            {{#if existingRate}}
            <div class="bg-stone-900 border border-stone-700 rounded-lg p-4 space-y-2">
                <p><strong>Score:</strong> {{existingRate.rating}} / 5</p>
                <p><strong>Comment:</strong> {{existingRate.comment}}</p>
            </div>
            {{else}}
                {{#if canRate}}
                <form action="/rates/submit" method="POST" class="space-y-4">
                    <input type="hidden" name="bookingId" value="{{booking._id}}">

                    <div>
                        <label class="block text-sm mb-2">Rating (1-5)</label>
                        <select name="rating" required class="w-full bg-stone-900 border border-stone-700 rounded-lg px-3 py-2">
                            <option value="">Select score</option>
                            <option value="5">5 - Excellent</option>
                            <option value="4">4 - Very good</option>
                            <option value="3">3 - Good</option>
                            <option value="2">2 - Fair</option>
                            <option value="1">1 - Poor</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm mb-2">Comment</label>
                        <textarea name="comment" rows="3" maxlength="500" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-3 py-2" placeholder="Share your experience..."></textarea>
                    </div>

                    <button type="submit" class="bg-yellow-500 text-black px-4 py-2 rounded-lg hover:bg-yellow-400">
                        Submit Rating
                    </button>
                </form>
                {{/if}}
            {{/if}}
        </div>

    </div>
</section>