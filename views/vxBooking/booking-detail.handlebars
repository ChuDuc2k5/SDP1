<section class="max-w-4xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-yellow-500 mb-6">
        Booking Details
    </h1>

    <div class="bg-stone-800 p-6 rounded-xl border border-stone-700">

        <h2 class="text-xl font-semibold mb-4">
            {{booking.cabin.name}}
        </h2>

        <div class="space-y-2 text-stone-300">
            <p><strong>Check-in:</strong> {{booking.startDate}}</p>
            <p><strong>Check-out:</strong> {{booking.endDate}}</p>
            <p><strong>Guests:</strong> {{booking.numGuests}}</p>
            <p><strong>Breakfast:</strong> {{#if booking.hasBreakfast}}Yes{{else}}No{{/if}}</p>
            <p><strong>Price:</strong> ${{booking.cabinPrice}}</p>
            <p><strong>Status:</strong> 
                <span class="
                    {{#if (eq booking.status 'confirmed')}}text-green-400{{/if}}
                    {{#if (eq booking.status 'cancelled')}}text-red-400{{/if}}
                ">
                    {{booking.status}}
                </span>
            </p>
            <p><strong>Note:</strong> {{booking.observations}}</p>
        </div>

        <div class="mt-6 flex gap-4">
            <a href="/account/bookings/{{booking._id}}/edit" 
               class="bg-yellow-500 text-black px-4 py-2 rounded-lg hover:bg-yellow-400">
                Edit Booking
            </a>

            <form action="/account/bookings/{{booking._id}}/cancel" method="POST">
                <button class="bg-red-600 px-4 py-2 rounded-lg hover:bg-red-500">
                    Cancel Booking
                </button>
            </form>
        </div>

    </div>
</section>