<section class="max-w-6xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-yellow-500 mb-6">
        My Bookings
    </h1>

    <div class="space-y-4">
        {{#each bookings}}
        <div class="bg-stone-800 p-6 rounded-xl border border-stone-700 flex justify-between items-center">
            
            <div>
                <h2 class="text-xl font-semibold">{{this.cabin.name}}</h2>
                <p class="text-stone-400">
                    {{this.startDate}} → {{this.endDate}}
                </p>
                <p class="text-stone-500 text-sm">
                    Guests: {{this.numGuests}}
                </p>
            </div>

            <div class="text-right">
                <p class="text-yellow-500 font-semibold">
                    ${{this.cabinPrice}}
                </p>

                <span class="text-sm 
                    {{#if (eq this.status 'confirmed')}}text-green-400{{/if}}
                    {{#if (eq this.status 'cancelled')}}text-red-400{{/if}}
                ">
                    {{this.status}}
                </span>

                <div class="mt-2">
                    <a href="/account/bookings/{{this._id}}" 
                       class="text-yellow-500 hover:underline text-sm">
                        View Details
                    </a>
                </div>
            </div>

        </div>
        {{/each}}
    </div>
</section>