<section class="max-w-6xl mx-auto px-6 py-10">
    <h1 class="text-3xl font-bold text-yellow-500 mb-6">
        {{#if isAdmin}}All Bookings{{else}}My Bookings{{/if}}
    </h1>

    {{#if success}}
    <div class="mb-6 rounded-xl border border-green-600 bg-green-900/40 p-4 text-green-200">
        Booking successfully created. You can see it in your booking list.
    </div>
    {{/if}}

    {{#if empty}}
    <div class="rounded-xl border border-stone-700 bg-stone-800 p-8 text-center text-stone-300">
        <p class="text-xl font-semibold text-white">You do not have any bookings yet.</p>
        <p class="mt-2 text-stone-400">Return to the cabin page to make a booking now.</p>
        <a href="/cabins"
            class="inline-block mt-4 bg-yellow-500 text-stone-900 px-4 py-2 rounded-lg hover:bg-yellow-400">View
            Cabins</a>
    </div>
    {{else}}
    <div class="space-y-4">
        {{#each bookings}}
        <div class="bg-stone-800 p-6 rounded-xl border border-stone-700 flex justify-between items-center">

            <div>
                <h2 class="text-xl font-semibold">{{this.cabin.name}}</h2>
                <p class="text-stone-400">
                    {{this.startDate}} → {{this.endDate}}
                </p>
                <p class="text-stone-500 text-sm">
                    Guests: {{this.numGuests}} | Type: {{this.type}}
                </p>
                {{#if ../isAdmin}}
                <p class="text-stone-400 text-sm">User ID: {{this.userId}}</p>
                {{/if}}
            </div>
            <div class="text-right">
                <span class="inline-block bg-stone-600 text-stone-300 px-3 py-1 rounded-full text-sm">
                    {{this.status}}
                </span>

                <div class="mt-2">
                    <a href="/booking/detail/{{this._id}}" class="text-yellow-500 hover:underline text-sm">
                        View Details
                    </a>
                </div>
            </div>

        </div>
        {{/each}}
    </div>
    {{/if}}
</section>