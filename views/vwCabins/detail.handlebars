<div class="bg-stone-900 min-h-screen p-8 text-stone-100">
    <div class="max-w-5xl mx-auto">
        <a href="/cabins" class="text-yellow-500 hover:underline mb-6 inline-block">&larr; Back to all cabins</a>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 mt-4">
            <div class="rounded-xl overflow-hidden shadow-2xl border border-stone-700">
                <img src="{{cabin.image}}" alt="{{cabin.name}}" class="w-full h-full object-cover">
            </div>

            <div>
                <h1 class="text-5xl font-serif font-bold text-white mb-4">{{cabin.name}}</h1>
                <p class="text-xl text-stone-400 mb-6 italic">"{{cabin.description}}"</p>

                <div class="space-y-4 border-t border-stone-800 pt-6">
                    <div class="flex items-center gap-3">
                        <span class="text-2xl font-bold text-yellow-500">${{cabin.regularPrice}}</span>
                        <span class="text-stone-500">per night</span>
                    </div>

                    <div class="flex items-center gap-2 text-stone-300">
                        <span class="font-semibold">Capacity:</span> Up to {{cabin.maxCapacity}} guests
                    </div>

                    {{#if cabin.discount}}
                    <div
                        class="bg-green-900/30 text-green-400 px-4 py-2 rounded-lg inline-block border border-green-800">
                        Special Discount: -${{cabin.discount}} off!
                    </div>
                    {{/if}}
                </div>

                <div class="mt-10">
                    {{#if currentUser}}
                    <a href="/booking/new/{{cabin._id}}"
                        class="block bg-yellow-600 hover:bg-yellow-500 text-stone-900 font-bold py-4 px-8 rounded-xl transition-all w-full text-lg text-center shadow-lg uppercase tracking-wider">
                        Book Now
                    </a>
                    {{else}}
                    <a href="/account/profile"
                        class="block bg-yellow-600 hover:bg-yellow-500 text-stone-900 font-bold py-4 px-8 rounded-xl transition-all w-full text-lg text-center shadow-lg uppercase tracking-wider">
                        Login to Book
                    </a>
                    <p class="mt-3 text-stone-400 text-sm">You can view cabin details freely; login is only required to
                        make a booking.</p>
                    {{/if}}
                </div>
            </div>
        </div>
    </div>
</div>