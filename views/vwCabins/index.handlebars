<div class="bg-stone-900 min-h-screen p-8">
    <div class="max-w-6xl mx-auto">
        
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-10 gap-4 border-b border-stone-800 pb-6">
            <div>
                <h1 class="text-4xl font-bold text-yellow-500">Our Luxury Cabins</h1>
                <p class="text-stone-400 mt-1">Discover the perfect stay for your next adventure.</p>
            </div>

            <div class="flex items-center gap-3 bg-stone-800 p-2 rounded-lg border border-stone-700">
                <label class="text-stone-400 text-sm font-semibold pl-2">SORT BY:</label>
                <select onchange="const params = new URLSearchParams(window.location.search); params.set('sort', this.value); params.set('page', '1'); window.location.href = '/cabins?' + params.toString();"
                        class="bg-transparent text-yellow-500 font-bold outline-none cursor-pointer pr-2">
                    <option value="default" {{#if (eq activeSort 'default')}}selected{{/if}}>Default (A-Z)</option>
                    <option value="price-asc" {{#if (eq activeSort 'price-asc')}}selected{{/if}}>Price: Low to High</option>
                    <option value="capacity-desc" {{#if (eq activeSort 'capacity-desc')}}selected{{/if}}>Capacity: Max Guests</option>
                    <option value="discount-desc" {{#if (eq activeSort 'discount-desc')}}selected{{/if}}>Discount: Best Deals</option>
                    <option value="rating-desc" {{#if (eq activeSort 'rating-desc')}}selected{{/if}}>Rating: Highest First</option>
                </select>
            </div>
        </div>

        {{#if empty}}
            <div class="text-center py-20">
                <p class="text-stone-500 text-xl">Hiện chưa có phòng nào khả dụng.</p>
                <a href="/cabins" class="text-yellow-500 underline mt-4 inline-block">Refresh list</a>
            </div>
        {{else}}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                {{#each cabins}}
                <div class="bg-stone-800 rounded-2xl overflow-hidden shadow-xl border border-stone-700 hover:border-yellow-600/50 transition-all group flex flex-col">
                    <div class="relative overflow-hidden h-52">
                        <img src="{{image}}" alt="{{name}}" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500">
                        {{#if discount}}
                        <div class="absolute top-4 right-4 bg-green-600 text-white text-xs font-bold px-3 py-1 rounded-full shadow-lg">
                            -${{discount}} OFF
                        </div>
                        {{/if}}
                    </div>

                    <div class="p-6 flex-1 flex flex-col">
                        <h3 class="text-xl font-bold text-white mb-2 group-hover:text-yellow-500 transition-colors">{{name}}</h3>
                        <p class="text-stone-400 text-sm mb-6 line-clamp-2 flex-1 italic">"{{description}}"</p>
                        
                        <div class="flex justify-between items-end border-t border-stone-700/50 pt-4">
                            <div>
                                <p class="text-stone-500 text-xs uppercase tracking-widest mb-1">Price per night</p>
                                <span class="text-yellow-500 font-bold text-2xl">${{regularPrice}}</span>
                            </div>
                            <div class="text-right">
                                <span class="bg-stone-900 text-stone-400 px-3 py-1 rounded-md text-[10px] uppercase font-bold border border-stone-700">
                                    Up to {{maxCapacity}} guests
                                </span>
                            </div>
                        </div>

                        <a href="/cabins/detail/{{_id}}" class="block w-full mt-6 bg-yellow-600 hover:bg-yellow-500 text-stone-900 text-center font-bold py-3 rounded-xl transition-all shadow-lg hover:-translate-y-0.5 active:translate-y-0">
                            Book Now
                        </a>
                    </div>
                </div>
                {{/each}}
            </div>

            {{#if pagination.showPagination}}
            <nav class="mt-12 flex justify-center" aria-label="Cabin pagination">
                <div class="flex flex-wrap items-center justify-center gap-2">
                    {{#if pagination.hasPrevPage}}
                    <a href="{{pagination.prevPageUrl}}" class="inline-flex h-11 items-center justify-center rounded-xl border border-stone-700 bg-stone-800 px-4 text-sm font-bold text-stone-200 shadow-lg transition-all hover:border-yellow-500 hover:bg-stone-700 hover:text-yellow-500">
                        Previous
                    </a>
                    {{else}}
                    <span class="inline-flex h-11 cursor-not-allowed items-center justify-center rounded-xl border border-stone-800 bg-stone-900 px-4 text-sm font-bold text-stone-600" aria-disabled="true">
                        Previous
                    </span>
                    {{/if}}

                    {{#each pagination.pages}}
                    {{#if isActive}}
                    <span class="inline-flex h-11 min-w-11 items-center justify-center rounded-xl border border-yellow-400 bg-yellow-500 px-4 text-sm font-extrabold text-stone-950 shadow-lg shadow-yellow-900/20" aria-current="page">
                        {{number}}
                    </span>
                    {{else}}
                    <a href="{{url}}" class="inline-flex h-11 min-w-11 items-center justify-center rounded-xl border border-stone-700 bg-stone-800 px-4 text-sm font-bold text-stone-300 transition-all hover:border-yellow-500 hover:bg-stone-700 hover:text-yellow-500">
                        {{number}}
                    </a>
                    {{/if}}
                    {{/each}}

                    {{#if pagination.hasNextPage}}
                    <a href="{{pagination.nextPageUrl}}" class="inline-flex h-11 items-center justify-center rounded-xl border border-stone-700 bg-stone-800 px-4 text-sm font-bold text-stone-200 shadow-lg transition-all hover:border-yellow-500 hover:bg-stone-700 hover:text-yellow-500">
                        Next
                    </a>
                    {{else}}
                    <span class="inline-flex h-11 cursor-not-allowed items-center justify-center rounded-xl border border-stone-800 bg-stone-900 px-4 text-sm font-bold text-stone-600" aria-disabled="true">
                        Next
                    </span>
                    {{/if}}
                </div>
            </nav>
            {{/if}}
        {{/if}}
    </div>
</div>
