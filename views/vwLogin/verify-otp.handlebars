<div class="d-flex justify-content-center align-items-center vh-100"
    style="background: url('/images/aboutBackground.jpg') center/cover no-repeat;">

    <!-- overlay -->
    <div class="position-absolute w-100 h-100"
        style="background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.6), rgba(0,0,0,0.9));">
    </div>

    <div class="card bg-dark bg-opacity-75 text-white p-4 shadow-lg"
        style="width: 400px; border-radius: 20px; z-index: 2;">

        <!-- Header -->
        <div class="text-center mb-4">
            <h2 class="fw-bold" style="margin-bottom: 10px">Verify OTP</h2>
            <p class="text-warning fst-italic">
                Enter the code sent to your email
            </p>
            <small class="text-light">{{email}}</small>
        </div>

        <!-- FORM -->
        <form method="POST" action="/auth/verify-otp">

            <input type="hidden" name="email" value="{{email}}" />

            <!-- OTP -->
            <div class="mb-3">
                <input name="otp" class="form-control bg-dark text-white border-warning text-center"
                    placeholder="Enter OTP" style="letter-spacing: 5px; font-size: 18px;" />
            </div>

            {{#if error}}
            <p class="text-danger text-center">{{error}}</p>
            {{/if}}

            <!-- Button -->
            <button type="submit" class="btn btn-warning w-100 fw-bold">
                Verify
            </button>

        </form>

        <!-- Back -->
        <div class="text-center mt-3">
            <i class="bi bi-arrow-left-short"></i>
            <a href="/auth/forget-password" class="text-warning text-decoration-underline">
                Back to Forgot Password
            </a>
        </div>
    </div>
</div>