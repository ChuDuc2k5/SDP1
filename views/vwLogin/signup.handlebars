<div class="d-flex justify-content-center align-items-center vh-100"
     style="background: url('/images/aboutBackground.jpg') center/cover no-repeat;">

  <!-- overlay -->
  <div class="position-absolute w-100 h-100"
       style="background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.6), rgba(0,0,0,0.9));">
  </div>

  <div class="card bg-dark bg-opacity-75 text-white p-4 shadow-lg"
       style="width: 420px; z-index: 2; border-radius: 20px;">

    <h2 class="text-center fw-bold">Create Account</h2>
    {{!-- <p class="text-warning text-center fst-italic">
      Join the Tranquility Retreat family!
    </p> --}}

    <form method="POST" action="/auth/signup">

      <!-- Full Name -->
      <div class="mb-3">
        <label class="form-label text-warning">Full Name</label>
        <input name="fullName"
               class="form-control bg-dark text-white border-warning"
               placeholder="Enter your full name" />
      </div>

      <!-- Email -->
      <div class="mb-3">
        <label class="form-label text-warning">Email</label>
        <input name="email" type="email"
               class="form-control bg-dark text-white border-warning"
               placeholder="example@gmail.com" />
      </div>

      <!-- Password -->
      <div class="mb-3">
        <label class="form-label text-warning">Password</label>
        <input name="password" type="password"
               class="form-control bg-dark text-white border-warning"
               placeholder="At least 6 characters" />
      </div>

      <!-- Phone -->
      <div class="mb-3">
        <label class="form-label text-warning">Phone Number</label>
        <input name="phone"
               class="form-control bg-dark text-white border-warning"
               placeholder="10–11 digits" />
      </div>

      <!-- National ID -->
      <div class="mb-3">
        <label class="form-label text-warning">National ID</label>
        <input name="nationalId"
               class="form-control bg-dark text-white border-warning"
               placeholder="9–12 digits" />
      </div>

      <!-- Date of Birth -->
      <div class="mb-3">
        <label class="form-label text-warning">Date of Birth</label>
        <input name="dateOfBirth" type="date"
               class="form-control bg-dark text-white border-warning" />
      </div>

      <button type="submit"
              class="btn btn-warning w-100 mt-3 fw-bold">
        Sign Up
      </button>
    </form>

    <div class="text-center mt-3">
      <i class="bi bi-arrow-left-short"></i>
      <a href="/auth/login" class="text-warning text-decoration-underline">
        Back to Log In
      </a>
    </div>

  </div>
</div>