<div class="d-flex justify-content-center align-items-center vh-100"
  style="background: url('/images/aboutBackground.jpg') center/cover no-repeat;">

  <!-- overlay -->
  <div class="position-absolute w-100 h-100"
    style="background: linear-gradient(to bottom, rgba(0,0,0,0.8), rgba(0,0,0,0.6), rgba(0,0,0,0.9));">
  </div>

  <div class="card bg-dark bg-opacity-75 text-white p-4 shadow-lg"
    style="width: 400px; z-index: 2; border-radius: 15px;">

    <!-- Header -->
    <div class="text-center mb-4">
      <h2 class="fw-bold">Log in</h2>
      <p class="text-warning fst-italic">
        Welcome back, our beloved customer!!!
      </p>

      {{#if success}}
      <p class="text-success fw-bold mt-2">
        {{success}}
      </p>
      {{/if}}
    </div>

    <!-- Form -->
    <form method="POST" action="/auth/login">

      <!-- Email -->
      <div class="mb-3">
        <input type="email" name="email" class="form-control bg-dark text-white border-warning" placeholder="Email" />
      </div>

      <!-- Password -->
      <div class="mb-3">
        <input type="password" name="password" class="form-control bg-dark text-white border-warning"
          placeholder="Password" />
      </div>

      <!-- Button -->
      <button type="submit" class="btn btn-warning w-100 fw-bold">
        Log in
      </button>

    </form>

    <!-- Links -->
    <div class="text-center mt-3">
      <a href="/auth/forget-password" class="text-warning text-decoration-underline">
        Forget password?
      </a>

      <p class="mt-2">
        Does not have a register account?
        <a href="/auth/signup" class="text-warning fw-bold text-decoration-underline">
          Sign up
        </a>
      </p>
    </div>

  </div>
</div>