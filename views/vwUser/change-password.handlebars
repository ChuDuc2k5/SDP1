<div class="d-flex justify-content-center align-items-center vh-100"
    style="background: url('/images/aboutBackground.jpg') center/cover no-repeat;">

    <div class="card bg-dark text-white p-4 shadow-lg" style="width: 450px; border-radius: 20px;">


        <h2 class="text-center fw-bold">Change Password</h2>
        <p class="text-warning text-center">
            Secure your account by updating your password
        </p>

        <form method="POST" action="/user/change-password">

            <!-- Current Password -->
            <div class="mb-3">
                <label class="form-label">Current Password</label>
                <input type="password" name="currentPassword" class="form-control bg-dark text-white border-warning"
                    placeholder="Enter current password" />
            </div>

            <!-- New Password -->
            <div class="mb-3">
                <label class="form-label">New Password</label>
                <input type="password" name="newPassword" class="form-control bg-dark text-white border-warning"
                    placeholder="At least 6 characters" />
            </div>

            <!-- Confirm Password -->
            <div class="mb-3">
                <label class="form-label">Confirm New Password</label>
                <input type="password" name="confirmPassword" class="form-control bg-dark text-white border-warning"
                    placeholder="Re-enter new password" />
            </div>

            {{#if error}}
            <p class="text-danger text-center">{{error}}</p>
            {{/if}}

            {{#if success}}
            <p class="text-success text-center">{{success}}</p>
            {{/if}}

            <button class="btn btn-warning w-100 fw-bold mt-2">
                Update Password
            </button>

        </form>

        <div class="text-center mt-3">
            <i class="bi bi-arrow-left"></i>
            <a href="/user/profile" class="text-warning text-decoration-underline">
                Back to Profile
            </a>
        </div>

    </div>
</div>