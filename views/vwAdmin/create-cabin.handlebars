<div class="max-w-3xl mx-auto">
    <div class="mb-8">
        <a href="/admin/cabins" class="text-stone-400 hover:text-yellow-500 text-sm flex items-center gap-2 mb-4">
            &larr; Back to Cabins
        </a>
        <h2 class="text-2xl font-serif font-bold text-yellow-500">Create New Cabin</h2>
    </div>

    <form action="/admin/cabins/add" method="POST" enctype="multipart/form-data" class="bg-stone-950/50 border border-stone-800 rounded-2xl p-8 space-y-6">
        <div class="grid grid-cols-2 gap-6">
            <!-- Các trường khác giữ nguyên -->
            <div class="col-span-2">
                <label class="block text-sm font-medium text-stone-300 mb-2">Cabin Name</label>
                <input type="text" name="name" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500" placeholder="e.g. The Lake View" required>
            </div>
            
            <div>
                <label class="block text-sm font-medium text-stone-300 mb-2">Max Capacity</label>
                <input type="number" name="maxCapacity" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500" placeholder="Number of guests" required>
            </div>

            <div>
                <label class="block text-sm font-medium text-stone-300 mb-2">Regular Price ($)</label>
                <input type="number" name="regularPrice" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500" placeholder="250" required>
            </div>

            <div>
                <label class="block text-sm font-medium text-stone-300 mb-2">Discount (%)</label>
                <input type="number" name="discount" value="0" min="0" max="100" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500">
            </div>

            <div class="col-span-2">
                <label class="block text-sm font-medium text-stone-300 mb-2">Description</label>
                <textarea name="description" rows="4" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500"></textarea>
            </div>

            <!-- ====================== PHẦN UPLOAD ẢNH MỚI ====================== -->
            <div class="col-span-2">
                <label class="block text-sm font-medium text-stone-300 mb-2">Upload Image</label>
                
                <input type="file" id="image-upload" name="image" accept="image/*" class="hidden">

                <div id="upload-area" 
                     class="border border-dashed border-stone-600 hover:border-yellow-500 rounded-2xl p-8 text-center cursor-pointer transition-colors">
                    <div class="mx-auto w-12 h-12 flex items-center justify-center text-4xl mb-3">📤</div>
                    <p class="text-stone-100 font-medium">Chọn ảnh từ máy tính</p>
                    <p class="text-stone-400 text-sm mt-1">hoặc kéo thả vào đây (PNG, JPG, GIF)</p>
                </div>

                <div id="preview-section" class="mt-6 hidden">
                    <p class="text-xs uppercase tracking-widest text-stone-400 mb-3">Ảnh preview</p>
                    <div class="relative rounded-3xl overflow-hidden border border-stone-700 bg-stone-900">
                        <img id="image-preview" src="" class="w-full h-auto max-h-[320px] object-cover" alt="Preview">
                        <button type="button" onclick="removePreview()" 
                                class="absolute top-4 right-4 bg-red-500 hover:bg-red-600 text-white rounded-2xl w-9 h-9 flex items-center justify-center text-2xl leading-none shadow-lg transition-colors">
                            ×
                        </button>
                    </div>
                    <p class="text-xs text-stone-500 mt-2">Ảnh sẽ được upload khi tạo cabin</p>
                </div>
            </div>
        </div>

        <div class="pt-4 border-t border-stone-800 flex justify-end">
            <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-stone-900 px-6 py-3 rounded-lg font-medium transition-colors">
                Create Cabin
            </button>
        </div>
    </form>
</div>

<!-- Script preview -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const fileInput = document.getElementById('image-upload');
        const uploadArea = document.getElementById('upload-area');
        const previewSection = document.getElementById('preview-section');
        const imagePreview = document.getElementById('image-preview');

        // Click để chọn file
        uploadArea.addEventListener('click', () => fileInput.click());

        // Xử lý khi chọn file
        fileInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function (e) {
                    imagePreview.src = e.target.result;
                    previewSection.classList.remove('hidden');
                    uploadArea.classList.add('hidden');
                };
                reader.readAsDataURL(file);
            }
        });

        // Drag & Drop
        uploadArea.addEventListener('dragover', e => {
            e.preventDefault();
            uploadArea.classList.add('border-yellow-500', 'bg-yellow-500/10');
        });
        uploadArea.addEventListener('dragleave', () => {
            uploadArea.classList.remove('border-yellow-500', 'bg-yellow-500/10');
        });
        uploadArea.addEventListener('drop', e => {
            e.preventDefault();
            uploadArea.classList.remove('border-yellow-500', 'bg-yellow-500/10');
            const file = e.dataTransfer.files[0];
            if (file && file.type.startsWith('image/')) {
                fileInput.files = e.dataTransfer.files;
                const event = new Event('change');
                fileInput.dispatchEvent(event);
            }
        });

        // Xóa preview
        window.removePreview = function () {
            previewSection.classList.add('hidden');
            uploadArea.classList.remove('hidden');
            fileInput.value = '';
        };
    });
</script>