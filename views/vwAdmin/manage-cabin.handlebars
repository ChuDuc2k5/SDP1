<div class="flex justify-between items-center mb-8">
    <a href="/admin/cabins/add" class="bg-yellow-500 hover:bg-yellow-400 text-stone-900 px-5 py-2.5 rounded-lg font-medium transition-colors shadow-lg">
        + Add New Cabin
    </a>
</div>

<div class="bg-stone-950/50 border border-stone-800 rounded-2xl overflow-hidden">
    <table class="w-full text-left border-collapse">
        <thead>
            <tr class="bg-stone-900 border-b border-stone-800 text-stone-300 text-sm uppercase tracking-wider">
                <th class="p-4 font-medium">Cabin</th>
                <th class="p-4 font-medium">Capacity</th>
                <th class="p-4 font-medium">Price / Night</th>
                <th class="p-4 font-medium">Discount</th>
                <th class="p-4 font-medium text-right">Actions</th>
            </tr>
        </thead>
        <tbody class="divide-y divide-stone-800 text-stone-300">
            {{#each cabins}}
            <tr class="hover:bg-stone-900/50 transition-colors">
                <td class="p-4 flex items-center gap-4">
                    <div class="w-16 h-16 rounded-lg bg-stone-800 bg-cover bg-center" style="background-image: url('{{this.image}}');"></div>
                    <div>
                        <div class="font-semibold text-stone-100">{{this.name}}</div>
                        <div class="text-xs text-stone-500">ID: {{this._id}}</div>
                    </div>
                </td>
                <td class="p-4">{{this.maxCapacity}} Guests</td>
                <td class="p-4 text-yellow-500 font-medium">${{this.regularPrice}}</td>
                <td class="p-4">{{this.discount}}%</td>
                <td class="p-4 text-right">
                    <a href="/admin/cabins/edit/{{this._id}}" class="text-blue-400 hover:text-blue-300 mr-3">Edit</a>
                    
                    <form action="/admin/cabins/delete/{{this._id}}" method="POST" class="inline-block" onsubmit="return confirm('Bạn có chắc chắn muốn xoá cabin này không?');">
                        <button type="submit" class="text-red-400 hover:text-red-300">Delete</button>
                    </form>
                </td>
            </tr>
            {{/each}}
            {{#if (eq cabins.length 0)}}
            <tr>
                <td colspan="5" class="p-4 text-center text-stone-500">Chưa có cabin nào trong hệ thống.</td>
            </tr>
            {{/if}}
        </tbody>
    </table>
</div>