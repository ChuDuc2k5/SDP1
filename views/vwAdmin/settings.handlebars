<div class="max-w-2xl mx-auto">
    <div class="mb-8">
        <h2 class="text-2xl font-serif font-bold text-yellow-500">System Settings</h2>
        <p class="text-stone-400 text-sm mt-1">Manage global booking rules and pricing.</p>
    </div>
{{#if success}}
<div class="bg-green-500/10 border border-green-500 text-green-400 px-4 py-2 rounded-lg mb-4">
    ✅ Settings updated successfully!
</div>
{{/if}}

{{#if error}}
<div class="bg-red-500/10 border border-red-500 text-red-400 px-4 py-2 rounded-lg mb-4">
    ❌ Update failed!
</div>
{{/if}}
    <form action="/admin/settings" method="POST" class="bg-stone-950/50 border border-stone-800 rounded-2xl p-8 space-y-6">
        <div>
            <label class="block text-sm font-medium text-stone-300 mb-2">Breakfast Price ($)</label>
            <input type="number" name="breakfastPrice" value="{{settings.breakfastPrice}}" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500">
            <p class="text-xs text-stone-500 mt-1">Price per guest per day.</p>
        </div>

        <div class="grid grid-cols-2 gap-6">
            <div>
                <label class="block text-sm font-medium text-stone-300 mb-2">Minimum Booking Length (Nights)</label>
                <input type="number" name="minBookingLength" value="{{settings.miniBookingLength}}" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500">
            </div>
            <div>
                <label class="block text-sm font-medium text-stone-300 mb-2">Maximum Booking Length (Nights)</label>
                <input type="number" name="maxBookingLength" value="{{settings.maxBookingLength}}" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500">
            </div>
        </div>

        <!-- === TRƯỜNG MỚI: Maximum Number of Guests === -->
        <div>
            <label class="block text-sm font-medium text-stone-300 mb-2">Maximum Number of Guests</label>
            <input type="number" name="maxGuests" value="{{settings.maxNumberOfGuests}}" class="w-full bg-stone-900 border border-stone-700 rounded-lg px-4 py-3 text-stone-100 focus:outline-none focus:border-yellow-500">
            <p class="text-xs text-stone-500 mt-1">Số khách tối đa cho mỗi booking (global setting).</p>
        </div>

        <div class="pt-4 border-t border-stone-800 flex justify-end">
            <button type="submit" class="bg-yellow-500 hover:bg-yellow-400 text-stone-900 px-6 py-3 rounded-lg font-medium transition-colors">
                Update Settings
            </button>
        </div>
    </form>
</div>